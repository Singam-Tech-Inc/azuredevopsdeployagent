# ----------------------------
# Core image configuration
# ----------------------------
IMAGE_REPO=azdevopsdeploymentagent
VERSION=1.0
TARGETARCH=arm64

# ----------------------------
# Runtime networking
# ----------------------------
HOST_HTTP_PORT=3000
AGENT_VOLUME_NAME=deploymentdevagent

# ----------------------------
# Traefik logging
# ----------------------------
TRAEFIK_LOG_LEVEL=INFO

# ----------------------------
# Azure DevOps agent settings
# ----------------------------
AZP_URL=https://dev.azure.com/<your-org>
AZP_TOKEN=<set-a-real-pat-locally>
AZP_PROJECT=<your-project>
AZP_ENVIRONMENT=development
AZP_AGENT_NAME=agent
